{
  "name": "vue-tron",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "description": "Yet another (e)mail building application",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build && electron-builder",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@nuxt/ui": "^4.9.0",
    "@pierre/trees": "^1.0.0-beta.4",
    "@types/mjml": "^5.0.0",
    "@vueuse/core": "^14.3.0",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "edge.js": "^6.5.1",
    "mjml": "^5.3.0",
    "mjml-msobutton": "^1.1.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-codemirror6": "^1.5.2",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.70.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.70.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
